{
  "name": "lovelace-ev-smart-charging-card",
  "version": "0.1.0",
  "description": "Lovelace custom card for the Smart EV Charging Home Assistant integration.",
  "type": "module",
  "main": "dist/ev-smart-charging-card.js",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --no-error-on-unmatched-pattern",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-lit": "^1.13.0",
    "happy-dom": "^15.0.0",
    "prettier": "^3.3.0",
    "rollup": "^4.20.0",
    "tslib": "^2.6.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
